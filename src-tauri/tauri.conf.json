{
  "productName": "Qise",
  "version": "0.1.0",
  "identifier": "com.qise.desktop",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd src-ui && npm run dev",
    "beforeBuildCommand": "cd src-ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Qise — AI Agent Security",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
