# Qise Bridge — Python HTTP server for Guard Pipeline analysis
# Receives guard check requests from Rust Proxy, runs Guard Pipeline + SLM

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends gcc \
    && rm -rf /var/lib/apt/lists/*

# Install Qise from source
COPY . /qise-src
RUN pip install --no-cache-dir "/qise-src[proxy]"

# Default shield.yaml will be mounted via volume
WORKDIR /opt/qise

EXPOSE 8823

CMD ["qise", "bridge", "start", "--port", "8823", "--config", "/opt/qise/shield.yaml"]
